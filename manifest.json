{
  "manifest_version": 3,
  "name": "GovMap Diff Viewer",
  "version": "0.1.0",
  "description": "Patches govmap to render a diff between two satellite image sources.",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.govmap.gov.il/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/*"
      ],
      "matches": [
        "https://www.govmap.gov.il/*"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "GovMap Diff Viewer"
  },
  "content_scripts": [
    {
      "matches": ["https://www.govmap.gov.il/*"],
      "js": ["src/bootstrap.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.govmap.gov.il/*"],
      "js": ["src/injectSettings.js"],
      "run_at": "document_start"
    }
  ]
}
